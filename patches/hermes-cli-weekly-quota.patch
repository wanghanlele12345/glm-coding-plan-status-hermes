+    @staticmethod
+    def _load_provider_usage_cache() -> Optional[Dict[str, Any]]:
+        """Load provider usage data from zai-statusline plugin cache.
+
+        Reads ~/.hermes/zai-usage-cache.json and returns the cached data dict
+        if available and not expired.  Returns None if no cache or stale.
+        """
+        try:
+            import json, time as _time
+            cache_path = Path.home() / ".hermes" / "zai-usage-cache.json"
+            if not cache_path.exists():
+                return None
+            raw = cache_path.read_text("utf-8")
+            cache = json.loads(raw)
+            data = cache.get("data", {})
+            ts = cache.get("timestamp", 0)
+            # Cache TTL: 330 seconds — must exceed the plugin's own 300s (5 min)
+            # refresh cycle so the TUI bar never goes blank between LLM turns.
+            if _time.time() * 1000 - ts > 330_000:
+                return None
+            if data.get("error"):
+                return None
+            return data
+        except Exception:
+            return None
+
